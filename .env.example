# =================================================
# Meta-Koda environment variables
# Copy to `.env` and fill in real values.
# =================================================

# ---------- Supabase ----------
# Project URL + service-role key from Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-jwt
# JWT secret (same project — for HS256 fallback verification)
SUPABASE_JWT_SECRET=your-jwt-secret

# Public keys (frontend reads these — safe to ship to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt

# Frontend → backend API base URL.
# Local dev: http://localhost:8000/api
# Production: https://your-backend.example.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Backend CORS allow-list — comma separated. Required in production so
# Vercel-hosted frontend can call your backend.
# Example: https://meta-koda.vercel.app,https://meta-koda.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-proj-...

# ---------- WhatsApp Business API (global fallback; per-tenant in DB) ----------
# Used as fallback only when a tenant has no whatsapp_accounts row.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=meta-koda-verify

# ---------- Google Form (post-dining feedback) ----------
GOOGLE_FORM_URL=

# ---------- Xendit (sandbox / production) ----------
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_CALLBACK_URL=

# ---------- Multi-tenant fallback ----------
# Default tenant slug used as a last-resort fallback in legacy code paths.
RESTAURANT_ID=default
