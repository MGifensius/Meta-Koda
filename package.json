{
  "name": "buranchi-koda",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "dotenv -e .env.local -- vitest run supabase/tests/rls.test.ts",
    "db:types": "supabase gen types typescript --local --schema public > packages/shared/src/types/database.ts",
    "seed:admin": "tsx scripts/seed-admin.ts"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.105.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.3.3",
    "supabase": "^1.219.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
